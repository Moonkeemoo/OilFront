# AISStream.io WebSocket API key — register at https://aisstream.io
AISSTREAM_KEY=replace_me

# Postgres+TimescaleDB (matches docker-compose.yml)
DATABASE_URL=postgresql://shadow:shadow_dev@localhost:5433/shadow

# Logging
LOG_LEVEL=info

# Bounding boxes for AIS subscription (JSON, [[[lat,lon],[lat,lon]], ...])
# Format per AISStream docs: [[[SW_lat, SW_lon], [NE_lat, NE_lon]], ...]
# Default: Baltic Sea + North Sea + Russian Baltic exit routes
AIS_BBOXES=[[[53,-10],[66,31]]]
